# Copier en .env.dev et renseigner les valeurs ci-dessous (ne pas committer .env.dev).
# MySQL exige des mots de passe non vides pour démarrer.
# Stack C# : docker compose --env-file .env.dev -f docker-compose.dev.yml up -d
# Stack Symfony : docker compose --env-file .env.dev -f docker-compose.dev-symfony.yml up -d

MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# Optionnel – stack Symfony uniquement
# APP_SECRET=change-me
# MERCURE_JWT_SECRET=!ChangeThisMercureHubJWTSecretKey!
# JWT_PASSPHRASE=
